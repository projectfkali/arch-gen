{
  "name": "@projectfkali/arch-gen",
  "version": "1.0.0",
  "description": "JSON DSL'den Java/C# proje iskeleti, SQL migration ve ER Diyagramı üreten geliştirici aracı",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/projectfkali/arch-gen.git"
  },
  "bugs": {
    "url": "https://github.com/projectfkali/arch-gen/issues"
  },
  "homepage": "https://github.com/projectfkali/arch-gen#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "arch-gen": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli/index.ts",
    "gui": "ts-node src/gui/server.ts",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "code-generator",
    "scaffold",
    "java",
    "csharp",
    "postgresql",
    "er-diagram",
    "migration"
  ],
  "author": "VCHelper",
  "dependencies": {
    "commander": "^11.0.0",
    "express": "^4.19.2",
    "fs-extra": "^11.1.1",
    "handlebars": "^4.7.8",
    "jszip": "^3.10.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/handlebars": "^4.1.0",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  }
